{
  "version": 1,
  "jobs": [
    {
      "id": "daily-standup-digest",
      "name": "Daily standup digest relay",
      "enabled": true,
      "createdAtMs": 1700000000000,
      "updatedAtMs": 1700000000000,
      "schedule": { "kind": "cron", "expr": "0 9 * * *" },
      "sessionTarget": { "kind": "new" },
      "wakeMode": "background",
      "payload": {
        "kind": "agentTurn",
        "message": "Post the daily standup summary to the team channel. Don't mention the confidential Q3 numbers."
      },
      "state": "active"
    }
  ]
}
