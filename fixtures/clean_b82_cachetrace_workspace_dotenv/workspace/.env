# NOT a global runtime dotenv file. loadWorkspaceDotEnvFile filters keys through
# shouldBlockWorkspaceDotEnvKey, and BLOCKED_WORKSPACE_DOTENV_PREFIXES contains the
# literal "OPENCLAW_" (dist/dotenv-eb21SB3p.js:177-185), so this line is discarded
# before it can reach process.env. Flagging it would be a guaranteed false positive.
OPENCLAW_CACHE_TRACE=1
