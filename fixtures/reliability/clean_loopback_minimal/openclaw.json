{
  "gateway": {
    "bind": "127.0.0.1:8080",
    "auth": { "mode": "token", "token": "minimum-32-character-secure-token-here" },
    "tailscale": { "funnel": false },
    "auth_no_rate_limit": false
  },
  "tools": {
    "profile": "minimal"
  },
  "sandbox": { "mode": "enabled", "network_mode": "bridge", "seccomp_profile": "default" },
  "logging": { "redactSensitive": true, "audit": true },
  "models": { "main": { "provider": "ollama/llama3" } }
}
