{
  "gateway": {
    "bind": "127.0.0.1:8080",
    "auth": { "mode": "token", "token": "a-very-long-token-of-32-characters" },
    "tailscale": { "funnel": false },
    "auth_no_rate_limit": false
  },
  "tools": {
    "profile": "minimal",
    "exec": { "mode": "ask" },
    "elevated": { "allowFrom": ["owner-123"] }
  },
  "agents": { "defaults": { "sandbox": { "mode": "non-main", "docker": { "network": "bridge" } } } },
  "plugins": {
    "allow": ["trentclaw"],
    "installs_unpinned_npm_specs": false,
    "installs_missing_integrity": false,
    "tools_reachable_policy": "restricted"
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "groupPolicy": "allowlist",
      "botToken": "env:TELEGRAM_BOT_TOKEN",
      "allowFrom": ["owner-123"],
      "groupAllowFrom": ["owner-123"],
      "contextVisibility": "allowlist",
      "requireMention": true,
      "groups": { "*": { "requireMention": true } },
      "accounts": { "primary": { "contextVisibility": "allowlist" } }
    }
  },
  "logging": { "redactSensitive": "tools", "audit": true },
  "models": { "main": { "provider": "local-llama" } }
}
