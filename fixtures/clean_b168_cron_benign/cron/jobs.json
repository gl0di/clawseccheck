{
  "version": 1,
  "jobs": [
    {
      "id": "daily-summary",
      "name": "Daily summary digest",
      "enabled": true,
      "createdAtMs": 1700000000000,
      "updatedAtMs": 1700000000000,
      "schedule": { "kind": "cron", "expr": "0 9 * * *" },
      "sessionTarget": { "kind": "new" },
      "wakeMode": "background",
      "payload": {
        "kind": "agentTurn",
        "message": "Summarize yesterday's completed tasks and post them to the team channel."
      },
      "state": "active"
    }
  ]
}
