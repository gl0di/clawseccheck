{
  "gateway": {
    "bind": "127.0.0.1:8080",
    "auth": { "mode": "token", "token": "a-very-long-token-of-32-characters" }
  },
  "channels": { "telegram": { "dmPolicy": "open", "groupPolicy": "open" } },
  "agents": {
    "defaults": {
      "subagents": { "maxSpawnDepth": 5, "maxChildrenPerAgent": 20, "maxConcurrent": 32 }
    }
  },
  "tools": { "profile": "minimal" },
  "logging": { "redactSensitive": "tools" },
  "models": { "main": { "provider": "ollama/llama3" } }
}
